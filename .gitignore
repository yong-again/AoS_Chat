# - data/pdfs : scripts/download_pdfs.py 로 재다운로드
data/
*.pdf
*.tmp
*.cache
*.log

# Scratch files
scratch/
temp.py
temp.ipynb

# Chroma vector DB (build_db.py 로 재생성)
my_warhammer_db/

